# ── Servidor ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Banco de Dados (PostgreSQL) ────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/promovix

# ── Auth (JWT) ─────────────────────────────────────────────
JWT_SECRET=troque-este-segredo-por-algo-longo-e-aleatorio
JWT_EXPIRES_IN=8h

# ── Cloudinary ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Asaas ──────────────────────────────────────────────────
ASAAS_API_KEY=
ASAAS_ENVIRONMENT=sandbox   # sandbox | production

# ── Google Gemini (principal) ──────────────────────────────
GEMINI_API_KEY=

# ── Groq (fallback — grátis em console.groq.com) ───────────
GROQ_API_KEY=

# ── Frontend (CORS) ────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Trial ──────────────────────────────────────────────────
TRIAL_DAYS=20
